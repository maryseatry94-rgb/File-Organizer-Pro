            self.lbl_ai.config(text="✅ IA prête", fg=self.T["success"],
                               bg=self.T["bg3"])
        else:
            self.lbl_ai.config(text="⚠️ IA non connectée", fg=self.T["warning"],
                               bg=self.T["bg3"])

    def _save_key(self):
        key = self.entry_key.get().strip()
        self.cfg["api_key"] = key
        save_json(CONFIG_F, self.cfg)
        self.ai_client = get_ai_client(key)
        self._refresh_ai_status()
        if self.ai_client:
            messagebox.showinfo("Succès", "Clé API sauvegardée ✅")
            if self.scanned:
                self.btn_ai.config(state="normal")
        else:
            messagebox.showerror("Erreur", "Clé API invalide ou openai non installé.\nLance : pip install openai")

    def _browse(self):
        folder = filedialog.askdirectory(title="Choisir un dossier")
        if folder:
            self.folder_path_str = folder
            self.folder_var.set(folder)

    def _get_projects(self) -> list[str]:
        return [p.strip() for p in self.entry_proj.get().split(",") if p.strip()]

    def _scan(self):
        path_str = self.folder_var.get().strip()
        if not path_str or not Path(path_str).is_dir():
            messagebox.showerror("Erreur", "Sélectionne un dossier valide.")
            return
        projects = self._get_projects()
        self.memory["projects"] = projects
        save_json(MEMORY_F, self.memory)

        self.scanned = scan_folder(Path(path_str), projects, self.recursive.get())
        self._refresh_tree()

        n    = len(self.scanned)
        dups = sum(1 for f in self.scanned if f["is_duplicate"])
        self.lbl_count.config(text=f"{n} fichier(s) — {dups} doublon(s)")
        self.btn_go.config(state="normal" if n else "disabled")
        self.btn_ai.config(state="normal" if n and self.ai_client else "disabled")
        self.progress_var.set(0)
        self.lbl_progress.config(text="")

    def _refresh_tree(self):
        self.tree.delete(*self.tree.get_children())
        for f in self.scanned:
            icon = CATEGORIES.get(f["category"], {}).get("icon", "📎")
            row = (
                f["name"],
                f"{icon} {f['category']}",
                f["project"] or "—",
                f["ai_name"] or "—",
                "⚠️" if f["is_duplicate"] else "",
            )
            tag = "dup" if f["is_duplicate"] else ""
            self.tree.insert("", "end", values=row, tags=(tag,))
        self.tree.tag_configure("dup", foreground=self.T["warning"])

    def _run_ai(self):
        if not self.ai_client:
            messagebox.showwarning("IA", "Entre une clé API valide.")
            return
        self.btn_ai.config(state="disabled")
        self.btn_scan.config(state="disabled")
        self.btn_go.config(state="disabled")

        def worker():
            total = len(self.scanned)
            for i, f in enumerate(self.scanned):
                if not f["is_duplicate"]:
                    suggestion = ai_suggest(self.ai_client, f["name"],
                                            f["category"], self.memory)
                    if suggestion:
                        f["ai_name"] = suggestion + f["ext"]
                pct = (i + 1) / total * 100
                self.progress_var.set(pct)
                self.lbl_progress.config(text=f"🧠 IA : {f['name']} ({i+1}/{total})")
                self.update_idletasks()

            self._refresh_tree()
            self.lbl_progress.config(text="✅ Suggestions IA générées !")
            self.btn_ai.config(state="normal")
            self.btn_scan.config(state="normal")
            self.btn_go.config(state="normal")

        threading.Thread(target=worker, daemon=True).start()

    def _organize(self):
        if not self.scanned:
            return
        folder = Path(self.folder_var.get())
        dups   = sum(1 for f in self.scanned if f["is_duplicate"])
        msg = f"{len(self.scanned)} fichier(s) vont être déplacés et renommés."
        if dups:
            msg += f"\n⚠️ {dups} doublon(s) → dossier 'Doublons'"
        if not messagebox.askyesno("Confirmer", msg + "\n\nContinuer ?"):
            return

        self.btn_go.config(state="disabled")
        self.btn_scan.config(state="disabled")
        counters: dict[str,int] = {}
        session_moves = []

        def worker():
            total = len(self.scanned)
            for i, f in enumerate(self.scanned):
                # Dossier de destination
                if f["is_duplicate"]:
                    dest_dir = folder / "Doublons"
                elif f["project"]:
                    dest_dir = folder / f["category"] / f["project"]
                else:
                    dest_dir = folder / f["category"]
                dest_dir.mkdir(parents=True, exist_ok=True)

                # Nom final
                if f["ai_name"]:
                    base = sanitize(Path(f["ai_name"]).stem)
                else:
                    cat = f["category"]
                    counters[cat] = counters.get(cat, 0) + 1
                    base = f"{cat}_{str(counters[cat]).zfill(3)}"

                dest_path = safe_dest(dest_dir, base, f["ext"])

                try:
                    shutil.move(str(f["path"]), str(dest_path))
                    session_moves.append({
                        "src": str(dest_path),
                        "dst": str(f["path"]),
                    })
                    self.memory["renamings"][f["name"]] = dest_path.name
                except Exception as e:
                    print(f"[MOVE ERROR] {f['name']}: {e}")

                pct = (i + 1) / total * 100
                self.progress_var.set(pct)
                self.lbl_progress.config(text=f"✅ {dest_path.name} ({i+1}/{total})")
                self.update_idletasks()

            # Sauvegarde historique & mémoire
            if session_moves:
                self.history.append({
                    "date": datetime.now().strftime("%Y-%m-%d %H:%M"),
                    "moves": session_moves,
                })
                save_json(HISTORY_F, self.history)
                save_json(MEMORY_F, self.memory)

            self.lbl_progress.config(text=f"🎉 {total} fichier(s) organisé(s) !")
            self.btn_scan.config(state="normal")
            self.btn_undo.config(state="normal")
            self.scanned = []
            self._refresh_tree()
            self.lbl_count.config(text="")
            messagebox.showinfo("Terminé !", f"🎉 {len(session_moves)} fichiers organisés avec succès !")

        threading.Thread(target=worker, daemon=True).start()

    def _undo(self):
        if not self.history:
            messagebox.showinfo("Annuler", "Aucune action à annuler.")
            return
        last = self.history[-1]
        moves = last.get("moves", [])
        if not messagebox.askyesno("Annuler",
            f"Annuler l'action du {last['date']} ?\n({len(moves)} fichier(s))"):
            return

        errors = 0
        for m in moves:
            try:
                src = Path(m["src"])
                dst = Path(m["dst"])
                dst.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(str(src), str(dst))
            except Exception as e:
                print(f"[UNDO] {e}")
                errors += 1

        self.history.pop()
        save_json(HISTORY_F, self.history)
        if errors:
            messagebox.showwarning("Annulation partielle",
                f"{errors} fichier(s) n'ont pas pu être restaurés.")
        else:
            messagebox.showinfo("Annulé ✅", "Tous les fichiers ont été restaurés !")
        self.btn_undo.config(state="normal" if self.history else "disabled")

