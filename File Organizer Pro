# ─── Helpers JSON ─────────────────────────────────────────────────────────────
def load_json(path, default):
    try:
        if path.exists():
            with open(path, "r", encoding="utf-8") as f:
                return json.load(f)
    except Exception:
        pass
    return default

def save_json(path, data):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

# ─── Logique fichiers ─────────────────────────────────────────────────────────
def get_category(extension: str) -> str:
    ext = extension.lower()
    for cat, data in CATEGORIES.items():
        if ext in data["extensions"]:
            return cat
    return "Autres"

def file_hash(filepath: Path) -> str | None:
    h = hashlib.md5()
    try:
        with open(filepath, "rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None

def extract_project(filename: str, known_projects: list[str]) -> str | None:
    stem = Path(filename).stem.lower()
    for proj in known_projects:
        if proj.lower() in stem:
            return proj
    parts = re.split(r"[_\-\s]+", stem)
    skip = {"final","test","new","old","copy","v1","v2","v3","v4","draft",
            "temp","wip","backup","render","export","import"}
    for part in parts:
        if len(part) > 2 and part not in skip and not part.isdigit():
            return part.capitalize()
    return None

def scan_folder(folder: Path, known_projects: list[str],
                recursive: bool = True) -> list[dict]:
    files = []
    hashes: dict[str, str] = {}
    skip_dirs = set(CATEGORIES.keys()) | {"Autres", "Doublons"}

    iterator = folder.rglob("*") if recursive else folder.iterdir()
    for f in iterator:
        if not f.is_file():
            continue
        # Ignore les dossiers déjà créés par l'outil
        rel_parts = f.relative_to(folder).parts
        if any(p in skip_dirs for p in rel_parts[:-1]):
            continue
        cat     = get_category(f.suffix)
        fhash   = file_hash(f)
        is_dup  = (fhash in hashes) if fhash else False
        if fhash and not is_dup:
            hashes[fhash] = str(f)
        files.append({
            "path":         f,
            "name":         f.name,
            "ext":          f.suffix.lower(),
            "category":     cat,
            "project":      extract_project(f.name, known_projects),
            "is_duplicate": is_dup,
            "hash":         fhash,
            "ai_name":      None,
        })
    return files

def sanitize(name: str) -> str:
    """Rend un nom sûr pour Windows."""
    name = re.sub(r'[\\/:*?"<>|\s]', "_", name)
    name = re.sub(r"_+", "_", name).strip("_")
    return name[:80]  # max 80 chars

def safe_dest(dest_folder: Path, base_name: str, ext: str) -> Path:
    """Retourne un chemin libre (ajoute _1, _2... si nécessaire)."""
    dest = dest_folder / (base_name + ext)
    counter = 1
    while dest.exists():
        dest = dest_folder / f"{base_name}_{counter}{ext}"
        counter += 1
    return dest

# ─── OpenAI ───────────────────────────────────────────────────────────────────
def get_ai_client(api_key: str):
    try:
        from openai import OpenAI
        return OpenAI(api_key=api_key)
    except Exception:
        return None

def ai_suggest(client, filename: str, category: str, memory: dict) -> str | None:
    past = list(memory.get("renamings", {}).items())[-8:]
    past_str = ", ".join(f"{k}->{v}" for k, v in past) or "aucun"
    prompt = (
        "You help a 3D game art student rename work files. "
        "Reply with ONE short filename (no extension, no spaces, use underscores, max 30 chars). "
        "Nothing else — just the name.\n"
        f"File: {filename}\nCategory: {category}\nPast renamings: {past_str}"
    )
    try:
        resp = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=25,
            temperature=0.3,
        )
        raw = resp.choices[0].message.content.strip()
        return sanitize(raw) or None
    except Exception as e:
        print(f"[AI] {filename}: {e}")
        return None

